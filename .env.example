# Runtime configuration for DAGs — copy to `.env` and fill in real values.
# `.env` is gitignored; never commit real folder IDs or secrets.
#
# Resolution order in the DAGs: DAG Param > .env / process env > Airflow Variable.

# Google Drive root folder IDs (folder that contains the institution subfolders).
STAFF_DRIVE_ROOT_FOLDER_ID=your_staff_drive_root_folder_id_here
CIARP_DRIVE_ROOT_FOLDER_ID=your_ciarp_drive_root_folder_id_here

# Email notifications on DAG completion (success + failure).
# Leave ALERT_EMAIL_TO empty to disable emails entirely.
ALERT_EMAIL_TO=you@example.com
# Sender domain we control (colav.co) so SPF/DKIM can authorize direct delivery.
# ALERT_EMAIL_FROM=airflow@colav.co
